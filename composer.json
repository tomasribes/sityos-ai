{
    "name": "sityos/automate",
    "description": "Sityos Automate — Drupal 11 platform for automation, AI tools, and digital productivity.",
    "type": "project",
    "license": "GPL-2.0-or-later",
    "homepage": "https://sityos.com",
    "minimum-stability": "stable",
    "prefer-stable": true,
    "require": {
        "composer/installers": "^2.0",
        "cweagans/composer-patches": "^1.7",
        "drupal/admin_toolbar": "^3.4",
        "drupal/adsense": "^1.5",
        "drupal/ai": "^1.3",
        "drupal/ai_provider_anthropic": "^1.2",
        "drupal/ai_provider_openai": "^1.2",
        "drupal/bootstrap_barrio": "^5.5",
        "drupal/config_split": "^2.0",
        "drupal/core-composer-scaffold": "^11",
        "drupal/core-recommended": "^11",
        "drupal/critical_css": "^2.0",
        "drupal/crop": "^2.6",
        "drupal/drupal_cms_olivero": "^1.2",
        "drupal/ds": "^3.37",
        "drupal/field_group": "^3.4",
        "drupal/focal_point": "^2.1",
        "drupal/gtm": "^1.10",
        "drupal/image_widget_crop": "^3.0",
        "drupal/languageicons": "^2.0@beta",
        "drupal/metatag": "^2.0",
        "drupal/paragraph_blocks": "^4.2",
        "drupal/paragraphs": "^1.17",
        "drupal/pathauto": "^1.12",
        "drupal/redirect": "^1.9",
        "drupal/redis": "^1.7",
        "drupal/schema_metatag": "^3.0",
        "drupal/seckit": "^2.0",
        "drupal/slick": "^3.0",
        "drupal/slick_views": "^3.0",
        "drupal/token": "^1.13",
        "drupal/views_slick_animate": "^3.5",
        "drupal/webp": "^1.0@alpha",
        "drupal/xmlsitemap": "^2.0",
        "drush/drush": "^13",
        "npm-asset/slick-carousel": "^1.8",
        "oomphinc/composer-installers-extender": "^2.0"
    },
    "require-dev": {
        "drupal/devel": "^5.0"
    },
    "config": {
        "sort-packages": true,
        "platform": {
            "php": "8.3.0"
        },
        "allow-plugins": {
            "composer/installers": true,
            "cweagans/composer-patches": true,
            "drupal/core-composer-scaffold": true,
            "oomphinc/composer-installers-extender": true
        },
        "preferred-install": {
            "twig/twig": "source"
        }
    },
    "extra": {
        "drupal-scaffold": {
            "locations": {
                "web-root": "docroot/"
            }
        },
        "installer-types": ["npm-asset", "bower-asset"],
        "installer-paths": {
            "docroot/core": ["type:drupal-core"],
            "docroot/libraries/{$name}": ["type:drupal-library", "type:npm-asset", "type:bower-asset"],
            "docroot/modules/contrib/{$name}": ["type:drupal-module"],
            "docroot/profiles/contrib/{$name}": ["type:drupal-profile"],
            "docroot/themes/contrib/{$name}": ["type:drupal-theme"]
        },
        "patches": {}
    },
    "repositories": [
        {
            "type": "composer",
            "url": "https://packages.drupal.org/8"
        },
        {
            "type": "composer",
            "url": "https://asset-packagist.org"
        }
    ],
    "scripts": {
        "post-install-cmd": [],
        "post-update-cmd": []
    }
}
