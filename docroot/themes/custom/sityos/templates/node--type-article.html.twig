{#
/**
 * @file
 * node--type-article.html.twig — Article content type template.
 *
 * Badge color: purple.
 *
 * Available variables (beyond Drupal core):
 *   - reading_time (int|null): minutes, computed in sityos_preprocess_node__article().
 *   - document_url (string|null): absolute URL to the PDF file.
 *   - document_name (string|null): original filename of the PDF.
 */
#}

{% set classes = [
  'node',
  'node--type-article',
  view_mode ? 'node--view-mode-' ~ view_mode|clean_class,
  not node.isPublished() ? 'node--unpublished',
] %}

<article{{ attributes.addClass(classes) }}>

  {% if not page %}
    {# ── Teaser / listing view ─────────────────────────────────────────────── #}
    <h3 class="node__title">
      <a href="{{ url }}" rel="bookmark">{{ label }}</a>
    </h3>

  {% else %}
    {# ── Full page view ────────────────────────────────────────────────────── #}

    {# 1. Hero image — full-width, above the header, with bottom gradient overlay #}
    {% if content.field_media_image|render|trim is not empty %}
      <div class="article-hero-image">
        {{ content.field_media_image }}
        <div class="article-hero-image__overlay" aria-hidden="true"></div>
      </div>
    {% endif %}

    {# 2. Article header — badges row, title, meta #}
    <header class="node__header">

      <div class="node__header-badges">
        <span class="node__type-badge node__type-badge--article">
          {{ 'Article'|t }}
        </span>

        {% if content.field_tags|render|trim is not empty %}
          <div class="node__header-tags" aria-label="{{ 'Topics'|t }}">
            {{ content.field_tags }}
          </div>
        {% endif %}
      </div>

      <h1 class="node__title">{{ label }}</h1>

      <div class="node__meta">
        {% if author_name %}
          <span class="node__author">
            <svg class="node__meta-icon" width="14" height="14" viewBox="0 0 24 24" fill="none" aria-hidden="true">
              <path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
              <circle cx="12" cy="7" r="4" stroke="currentColor" stroke-width="2"/>
            </svg>
            {{ author_name }}
          </span>
        {% endif %}

        <time class="node__date" datetime="{{ node.getCreatedTime()|date('c') }}">
          <svg class="node__meta-icon" width="14" height="14" viewBox="0 0 24 24" fill="none" aria-hidden="true">
            <rect x="3" y="4" width="18" height="18" rx="2" ry="2" stroke="currentColor" stroke-width="2"/>
            <line x1="16" y1="2" x2="16" y2="6" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
            <line x1="8" y1="2" x2="8" y2="6" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
            <line x1="3" y1="10" x2="21" y2="10" stroke="currentColor" stroke-width="2"/>
          </svg>
          {{ date }}
        </time>

        {% if reading_time %}
          <span class="node__reading-time">
            <svg class="node__meta-icon" width="14" height="14" viewBox="0 0 24 24" fill="none" aria-hidden="true">
              <circle cx="12" cy="12" r="10" stroke="currentColor" stroke-width="2"/>
              <polyline points="12 6 12 12 16 14" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
            {{ reading_time }} {{ 'min read'|t }}
          </span>
        {% endif %}
      </div>

    </header>

    {# 3. Main prose content — explicit fields excluded, rendered separately below #}
    <div class="node__content">
      {{ content|without('field_media_image', 'field_tags', 'field_media_document', 'comment', 'links') }}
    </div>

    {# 4. Article footer — separator + tags for discoverability #}
    {% if content.field_tags|render|trim is not empty %}
      <footer class="article-footer">
        <hr class="article-footer__divider" aria-hidden="true" />
        <div class="article-footer__tags" aria-label="{{ 'Filed under'|t }}">
          <span class="article-footer__tags-label">{{ 'Filed under'|t }}</span>
          {{ content.field_tags }}
        </div>
      </footer>
    {% endif %}

    {# 5. Document download card — styled CTA, only if file resolved in preprocess #}
    {% if document_url %}
      <aside class="article-download" aria-label="{{ 'Downloadable resource'|t }}">
        <div class="article-download__icon" aria-hidden="true">
          <svg width="24" height="24" viewBox="0 0 24 24" fill="none">
            <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
            <polyline points="14 2 14 8 20 8" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
            <line x1="12" y1="18" x2="12" y2="12" stroke="currentColor" stroke-width="2" stroke-linecap="round"/>
            <polyline points="9 15 12 18 15 15" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
          </svg>
        </div>
        <div class="article-download__content">
          <p class="article-download__label">{{ 'Downloadable Resource'|t }}</p>
          <p class="article-download__name">{{ document_name }}</p>
        </div>
        <a
          class="article-download__cta"
          href="{{ document_url }}"
          download
          aria-label="{{ 'Download @name'|t({'@name': document_name}) }}"
        >
          {{ 'Download PDF'|t }}
        </a>
      </aside>
    {% endif %}

    {# 6. Comments section #}
    {% if content.comment %}
      <section class="article-comments" aria-label="{{ 'Comments'|t }}">
        {{ content.comment }}
      </section>
    {% endif %}

    {# 7. Node links (edit, delete) — hidden visually but available to admins #}
    <div class="visually-hidden">
      {{ content.links }}
    </div>

  {% endif %}

</article>
