{#
/**
 * @file
 * links--language-block.html.twig — Language switcher dropdown.
 *
 * Variables:
 *   - links: Language links keyed by language code (en, es, ca).
 *   - current_lang: Active language code, set via sityos_preprocess_links__language_block().
 *
 * Each item in `links` has:
 *   - item.link: Render array for the <a> element.
 *   - item.text: Language name (TranslatableMarkup).
 *   - item.attributes: Attributes for the wrapper element.
 */
#}
{% if links %}
  <div class="lang-switcher" data-lang-switcher>

    <button
      class="lang-switcher__toggle"
      type="button"
      aria-expanded="false"
      aria-haspopup="listbox"
      aria-label="{{ 'Switch language'|t }}"
    >
      <span class="lang-switcher__flag lang-flag--{{ current_lang }}" aria-hidden="true"></span>
      <span class="lang-switcher__code">{{ current_lang|upper }}</span>
      <svg class="lang-switcher__arrow" aria-hidden="true" xmlns="http://www.w3.org/2000/svg" width="10" height="6" viewBox="0 0 10 6" fill="none">
        <path d="M1 1l4 4 4-4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
      </svg>
    </button>

    <ul class="lang-switcher__dropdown" role="listbox" aria-label="{{ 'Available languages'|t }}">
      {% for key, item in links %}
        {% if key != current_lang %}
          <li class="lang-switcher__option" role="option">
            <span class="lang-switcher__flag lang-flag--{{ key }}" aria-hidden="true"></span>
            {{ item.link }}
          </li>
        {% endif %}
      {% endfor %}
    </ul>

  </div>
{% endif %}
