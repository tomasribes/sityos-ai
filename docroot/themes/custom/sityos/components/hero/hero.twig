{#
  Hero component — editorial full-bleed.

  Props:
    - eyebrow (string): Category label above headline
    - headline (string, required): Main heading. Supports <em> for accent color.
    - subtitle (string): Supporting paragraph
    - image_url (string): Full-bleed background image URL
    - image_alt (string): Background image alt text
    - cta_primary_label (string): Primary button text
    - cta_primary_url (string): Primary button link
    - cta_secondary_label (string): Secondary button text
    - cta_secondary_url (string): Secondary button link
    - overlay_opacity (number): 0–1, default 0.6
#}

<section class="sityos-hero" style="--hero-overlay-opacity: {{ overlay_opacity ?? 0.6 }}">
  {% if image_url %}
    <img class="sityos-hero__media" src="{{ image_url }}" alt="{{ image_alt ?? '' }}" loading="eager" fetchpriority="high" />
  {% endif %}

  <div class="sityos-hero__overlay" aria-hidden="true"></div>

  <div class="sityos-hero__content layout-container">
    {% if eyebrow %}
      <span class="sityos-hero__eyebrow">{{ eyebrow }}</span>
    {% endif %}

    <h1 class="sityos-hero__headline">{{ headline }}</h1>

    {% if subtitle %}
      <p class="sityos-hero__subtitle">{{ subtitle }}</p>
    {% endif %}

    {% if cta_primary_label and cta_primary_url %}
      <div class="sityos-hero__actions">
        <a class="sityos-cta-button sityos-cta-button--primary sityos-cta-button--lg" href="{{ cta_primary_url }}">
          {{ cta_primary_label }}
        </a>

        {% if cta_secondary_label and cta_secondary_url %}
          <a class="sityos-cta-button sityos-cta-button--ghost sityos-cta-button--lg" href="{{ cta_secondary_url }}">
            {{ cta_secondary_label }}
          </a>
        {% endif %}
      </div>
    {% endif %}
  </div>

  <div class="sityos-hero__scroll" aria-hidden="true">
    <span class="sityos-hero__scroll-line"></span>
  </div>
</section>
