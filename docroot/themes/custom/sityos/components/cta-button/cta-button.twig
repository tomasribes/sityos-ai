{#
  CTA Button component.

  Props:
    - label (string, required)
    - url (string, required)
    - variant (string): primary | secondary | ghost — default: primary
    - size (string): sm | md | lg — default: md
    - external (bool): opens in new tab — default: false
#}
{% set variant = variant ?? 'primary' %}
{% set size = size ?? 'md' %}
{% set external = external ?? false %}
{% set target = external ? '_blank' : '_self' %}
{% set rel = external ? 'noopener noreferrer' : '' %}

<a
  class="sityos-cta-button sityos-cta-button--{{ variant }} sityos-cta-button--{{ size }}"
  href="{{ url }}"
  target="{{ target }}"
  {% if rel %}rel="{{ rel }}"{% endif %}
>
  {{- label -}}
  {% if external %}
    <span class="sityos-cta-button__external-icon" aria-label="{{ 'Opens in new tab'|t }}" aria-hidden="true">↗</span>
  {% endif %}
</a>
