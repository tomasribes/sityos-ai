# -- SityosHeroHomeBlock --
msgid "AI Automation Platform"
msgstr "Plataforma de Automatización IA"

msgid "Automate Smarter. <em>Work Less.</em> Achieve More."
msgstr "Automatiza con Inteligencia. <em>Trabaja Menos.</em> Consigue Más."

msgid "Sityos gives teams the practical AI workflows, tutorials, and tools they need to eliminate repetitive work and focus on what matters."
msgstr "Sityos proporciona a los equipos los flujos de trabajo IA prácticos, tutoriales y herramientas que necesitan para eliminar el trabajo repetitivo y centrarse en lo que importa."

msgid "Explore Tutorials →"
msgstr "Explorar Tutoriales →"

msgid "See Use Cases"
msgstr "Ver Casos de Uso"

msgid "Join professionals already saving hours every week."
msgstr "Únete a profesionales que ya ahorran horas cada semana."

