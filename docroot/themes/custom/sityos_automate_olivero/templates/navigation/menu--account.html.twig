{#
/**
 * @file
 * Account menu — icon-only on desktop header, icon + label in mobile drawer.
 *
 * Icon selection via route name (language-independent):
 *   user.login              → arrow-into-bracket (log in)
 *   user.logout             → arrow-out-of-bracket (log out)
 *   entity.user.canonical   → user silhouette (my account)
 */
#}
<nav class="account-menu-nav" aria-label="{{ 'User account'|t }}">
  <ul class="account-menu">
    {% for item in items %}
      {%- set route = item.url.routeName -%}

      {# ── Login icon ── #}
      {%- if route == 'user.login' -%}
        {%- set icon -%}
          <svg class="account-menu__icon" viewBox="0 0 24 24" aria-hidden="true"
               fill="none" stroke="currentColor" stroke-width="1.5"
               stroke-linecap="round" stroke-linejoin="round">
            <path d="M15 3h4a2 2 0 0 1 2 2v14a2 2 0 0 1-2 2h-4"/>
            <polyline points="10 17 15 12 10 7"/>
            <line x1="15" y1="12" x2="3" y2="12"/>
          </svg>
        {%- endset -%}

      {# ── Logout icon ── #}
      {%- elseif route == 'user.logout' -%}
        {%- set icon -%}
          <svg class="account-menu__icon" viewBox="0 0 24 24" aria-hidden="true"
               fill="none" stroke="currentColor" stroke-width="1.5"
               stroke-linecap="round" stroke-linejoin="round">
            <path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4"/>
            <polyline points="16 17 21 12 16 7"/>
            <line x1="21" y1="12" x2="9" y2="12"/>
          </svg>
        {%- endset -%}

      {# ── My account icon (default — entity.user.canonical or user.page) ── #}
      {%- else -%}
        {%- set icon -%}
          <svg class="account-menu__icon" viewBox="0 0 24 24" aria-hidden="true"
               fill="none" stroke="currentColor" stroke-width="1.5"
               stroke-linecap="round" stroke-linejoin="round">
            <path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/>
            <circle cx="12" cy="7" r="4"/>
          </svg>
        {%- endset -%}
      {%- endif -%}

      {%- set btn_attrs = create_attribute({
        'class': ['account-menu__btn'] | merge(item.in_active_trail ? ['is-active'] : []),
        'aria-label': item.title,
        'data-tooltip': item.title,
      }) -%}

      <li class="account-menu__item{{ item.in_active_trail ? ' is-active-trail' }}">
        <a href="{{ item.url }}"{{ btn_attrs }}>
          {{- icon -}}
          <span class="account-menu__label">{{ item.title }}</span>
        </a>
      </li>
    {% endfor %}
  </ul>
</nav>
