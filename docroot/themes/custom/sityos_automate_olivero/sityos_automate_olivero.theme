<?php

/**
 * @file
 * Functions to support theming in the Sityos Automate Olivero theme.
 */

declare(strict_types=1);

/**
 * Implements hook_preprocess_links__language_block().
 *
 * Exposes current_lang so the template can identify the active language
 * and attaches the language-switcher library.
 */
function sityos_automate_olivero_preprocess_links__language_block(array &$variables): void {
  $current_language = \Drupal::languageManager()->getCurrentLanguage();
  $variables['current_lang'] = $current_language->getId();
  $variables['current_lang_name'] = $current_language->getName();

  // Flag image URL from the languageicons contrib module.
  $module_path = \Drupal::service('extension.list.module')
    ->getPath('languageicons');
  $variables['current_lang_flag_url'] = base_path() . $module_path . '/flags/' . $current_language->getId() . '.png';

  $variables['#attached']['library'][] = 'sityos_automate_olivero/language-switcher';
}

/**
 * Implements hook_preprocess_html().
 */
function sityos_automate_olivero_preprocess_html(array &$variables): void {
  $variables['sao_path'] = \Drupal::service('extension.list.theme')
    ->getPath('sityos_automate_olivero');

  // Add <link rel="preload"> for the hero AVIF image on full node pages.
  $route_match = \Drupal::routeMatch();
  $node = $route_match->getParameter('node');
  if ($node instanceof \Drupal\node\NodeInterface) {
    $media_data = _sityos_get_media_image_file($node);
    if ($media_data) {
      $hero_data = _sityos_hero_image_data($media_data['file'], $media_data['alt']);
      $avif_source = $hero_data['picture_sources'][0] ?? NULL;
      if ($avif_source && !empty($avif_source['srcset'])) {
        $variables['head_tags'][] = [
          '#type' => 'html_tag',
          '#tag' => 'link',
          '#attributes' => [
            'rel'            => 'preload',
            'as'             => 'image',
            'type'           => 'image/avif',
            'imagesrcset'    => $avif_source['srcset'],
            'imagesizes'     => $avif_source['sizes'],
            'fetchpriority'  => 'high',
          ],
        ];
      }
    }
  }

  // Homepage SEO: Schema JSON-LD + meta description.
  $is_front = \Drupal::service('path.matcher')->isFrontPage();
  if ($is_front) {
    $lang = \Drupal::languageManager()->getCurrentLanguage()->getId();

    [$meta_title, $meta_description] = match ($lang) {
      'es' => [
        'Sityos Automate — Tutoriales y Casos de Uso de Automatización IA',
        'Flujos de trabajo IA prácticos, tutoriales paso a paso y casos de uso reales para equipos. Elimina el trabajo repetitivo y trabaja de forma más inteligente.',
      ],
      'ca' => [
        "Sityos Automate — Tutorials i Casos d'Ús d'Automatització IA",
        "Fluxos de treball IA pràctics, tutorials pas a pas i casos d'ús reals per a equips. Elimina la feina repetitiva i treballa de manera més intel·ligent.",
      ],
      default => [
        'Sityos Automate — AI Workflow Automation Tutorials & Use Cases',
        'Practical AI automation workflows, step-by-step tutorials, and real-world use cases for teams. Eliminate repetitive work and work smarter.',
      ],
    };

    $variables['#attached']['html_head'][] = [
      [
        '#type' => 'html_tag',
        '#tag' => 'meta',
        '#attributes' => ['name' => 'description', 'content' => $meta_description],
      ],
      'meta_description_homepage',
    ];

    // Schema JSON-LD — Organization + WebSite.
    // [DATO PLACEHOLDER] sameAs: replace [] with real social URLs before launch.
    $schema = [
      '@context' => 'https://schema.org',
      '@graph' => [
        [
          '@type' => 'Organization',
          'name' => 'Sityos Automate',
          'url' => 'https://www.sityos.com/',
          'logo' => 'https://www.sityos.com/themes/custom/sityos_automate_olivero/logo.svg',
          'sameAs' => [],
          'description' => 'AI workflow automation tutorials and use cases for modern teams.',
        ],
        [
          '@type' => 'WebSite',
          'url' => 'https://www.sityos.com/',
          'name' => 'Sityos Automate',
          'inLanguage' => ['en', 'es', 'ca'],
        ],
      ],
    ];

    $variables['#attached']['html_head'][] = [
      [
        '#type' => 'html_tag',
        '#tag' => 'script',
        '#value' => json_encode($schema, JSON_UNESCAPED_UNICODE | JSON_UNESCAPED_SLASHES | JSON_PRETTY_PRINT),
        '#attributes' => ['type' => 'application/ld+json'],
      ],
      'schema_jsonld_homepage',
    ];
  }
}

