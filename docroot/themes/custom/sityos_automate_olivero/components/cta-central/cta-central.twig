{#
  CTA Central — full-width conversion section.

  Props:
    - headline (string, required)
    - body (string)
    - cta_primary_label, cta_primary_url (required)
    - cta_secondary_label, cta_secondary_url (optional)
    - microcopy (string)
#}

<section class="sao-cta-central" aria-labelledby="sao-cta-central-heading">
  <div class="sao-cta-central__inner">
    <h2 class="sao-cta-central__headline" id="sao-cta-central-heading">
      {{ headline|raw }}
    </h2>

    {% if body %}
      <p class="sao-cta-central__body">{{ body }}</p>
    {% endif %}

    <div class="sao-cta-central__actions">
      {% include 'sityos_automate_olivero:cta-button' with {
        label: cta_primary_label,
        url: cta_primary_url,
        variant: 'primary',
        size: 'lg',
      } only %}

      {% if cta_secondary_label and cta_secondary_url %}
        {% include 'sityos_automate_olivero:cta-button' with {
          label: cta_secondary_label,
          url: cta_secondary_url,
          variant: 'ghost',
          size: 'lg',
        } only %}
      {% endif %}
    </div>

    {% if microcopy %}
      <p class="sao-cta-central__microcopy">{{ microcopy }}</p>
    {% endif %}
  </div>
</section>
