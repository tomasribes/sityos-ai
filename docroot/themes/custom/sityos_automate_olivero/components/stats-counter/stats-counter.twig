{#
  Stats Counter — animated numeric display.

  Props:
    - items (array of {value, suffix, label})
    - variant: row | grid — default: row
    - animate (bool): enable count-up — default: true
#}
{% set variant = variant ?? 'row' %}
{% set animate = animate ?? true %}

<section class="sao-stats sao-stats--{{ variant }}" role="list" aria-label="{{ 'Key statistics'|t }}">
  {% for item in items %}
    <div
      class="sao-stats__item"
      role="listitem"
      aria-label="{{ item.value }}{{ item.suffix ?? '' }} {{ item.label }}"
      {% if animate %}
        data-sao-counter
        data-sao-counter-target="{{ item.value }}"
      {% endif %}
    >
      <span class="sao-stats__value">
        <span class="sao-stats__number" {% if animate %}data-sao-counter-value{% endif %}>
          {% if animate %}0{% else %}{{ item.value }}{% endif %}
        </span>
        {% if item.suffix %}
          <span class="sao-stats__suffix">{{ item.suffix }}</span>
        {% endif %}
      </span>
      <span class="sao-stats__label">{{ item.label }}</span>
    </div>
  {% endfor %}
</section>
